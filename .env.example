NODE_ENV=development
AWS_REGION=ap-northeast-2

# App
APP_ENV=dev
LOG_LEVEL=debug
GATEWAY_PORT=3000

# Multi-tenant
TENANT_HEADER=x-tenant-id
REQUEST_ID_HEADER=x-request-id

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/multi_tenant

# Redis
REDIS_URL=redis://localhost:6379

# AWS resources
EVENT_BUS_NAME=multi-tenant-dev-bus
FILE_BUCKET_NAME=multi-tenant-dev-files
WMS_EVENT_QUEUE_URL=http://localhost:4566/000000000000/wms-events
